#!/usr/bin/env bash
set -euo pipefail

# Preconditions
git rev-parse --git-dir >/dev/null 2>&1 || {
    echo "Error: Not in a git repository" >&2
    exit 1
}

command -v fzf >/dev/null 2>&1 || {
    echo "Error: fzf is not installed" >&2
    exit 1
}

help() {
    cat <<EOF
Usage: gsc [OPTIONS]

OPTIONS:
    -s,  --show         Show commit(s)
    -d,  --diff         Diff commit(s)
    -rb, --rebase       Rebase onto commit (single)
    -rs, --reset        Reset --soft to commit (single)
    -rh, --reset-hard   Reset --hard to commit (single)
    -c,  --checkout     Checkout commit (single)
    -h,  --help
EOF
}

mode="print"

case "${1:-}" in
    "") mode="print" ;;
    -s|--show) mode="show" ;;
    -d|--diff) mode="diff" ;;
    -rb|--rebase) mode="rebase" ;;
    -rs|--reset) mode="reset" ;;
    -rh|--reset-hard) mode="reset-hard" ;;
    -c|--checkout) mode="checkout" ;;
    -h|--help) help; exit 0 ;;
    *) echo "Error: Unknown option $1" >&2; help; exit 1 ;;
esac

mapfile -t selection < <(
    git log --graph --pretty=format:"%h | %<(16,trunc)%cr [%an] %s %d" |
    fzf --ansi --no-sort --reverse \
        --bind 'ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up,ctrl-s:toggle-preview' \
        --preview 'git --no-pager show --color=always {2}' \
        --preview-window right:70% |
    awk '{print $2}'
)

[ "${#selection[@]}" -eq 0 ] && exit 0

case "$mode" in
    print) printf '%s\n' "${selection[@]}" ;;
    show) git show "${selection[@]}" ;;
    diff) git diff "${selection[@]}" ;;
    rebase) git rebase "${selection[0]}" ;;
    reset) git reset --soft "${selection[0]}" ;;
    reset-hard) git reset --hard "${selection[0]}" ;;
    checkout) git checkout "${selection[0]}" ;;
esac
