{
    "layer": "top",
    "position": "top",  // or "bottom", "left", "right"
    "exclusive": true,  // set to false if you want to hide bar
    "spacing": 0,
    "margin-left": 0,
    "margin-top": 0,
    "margin-right": -1,
    "sort-by-number": true,

    "modules-left": [
        "custom/power",
        "tray"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "memory",
        "cpu",
        "backlight",
        "pulseaudio",
        "bluetooth",
        "network",
        "custom/vpn",
        "battery"
    ],

    "custom/power": {
        "format" : "´ÇĹ ",
        "tooltip": false,
        "menu": "on-click",
        "menu-file": "~/.config/waybar/power_menu.xml",
        "menu-actions": {
            "shutdown": "shutdown now",
            "reboot": "reboot",
            "suspend": "systemctl suspend",
            "hibernate": "systemctl hibernate"
        }
    },

    "memory": {
        "interval": 3,
        "format": "ţ┐ů {used}GiB",
        "on-click": "alacritty -e btop",
        "tooltip": true
    },

    "cpu": {
        "interval": 3,
        "format": "{icon0}{icon1}{icon2}{icon3} {usage:>2}%",
        "format-icons": ["Ôľü", "Ôľé", "Ôľâ", "Ôľä", "Ôľů", "Ôľć", "Ôľç", "Ôľł"],
        "tooltip": true,
        "on-click": "alacritty -e btop"
    },

    "bluetooth": {
        "interval": 30,
        "format": "´Őö",
        "format-no-controller": "",
        "format-disabled": "ˇ░é▓",
        "format-connected": "´Őö {device_alias}",
        "format-connected-battery": "´Őö {device_alias} ({device_battery_percentage}%)",

        "tooltip-format": "All devices:\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "\t{device_alias}",
        "tooltip-format-enumerate-connected-battery": "\t{device_alias} ({device_battery_percentage}%)",

        "tooltip-format":                "{status}\n\nDevices:\n{device_enumerate}",
        "tooltip-format-enumerate":      "\tÔÇó {device_alias} [{device_battery_percentage}%]\n",
        "tooltip-format-enumerate-no-bat":"\tÔÇó {device_alias}\n",

        "on-click": "alacritty -e bluetui",
        "on-right-click":"bluetoothctl power toggle",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-muted": "  ˇ░ľü  ",
        "format-icons": {
            "headphones": "´Çą",
            "handsfree": "´Çą",
            "headset": "´Çą",
            "phone": "´éĽ",
            "phone-muted": "´äÖ",
            "portable": "´äő",
            "default": ["´Çž", "´ÇĘ"]
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +1%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -1%",
        "smooth-scrolling-threshold": 2
    },

    "backlight": {
        "device": "amd_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["ţĆĽ", "ţĆô", "ţĆô", "ţĆĺ", "ţĆĹ", "ţĆÉ", "ţĆĆ", "ţĆÄ", "ţĆŹ", "ţĆî", "ţĆő", "ţĆŐ", "ţĆë", "ţĆł", "ţĆú"],
        "on-click": "brightnessctl set 20%",
        "on-click-right": "brightnessctl set 65%",
        "smooth-scrolling-threshold": 2,
        "tooltip": false
    },

    "network": {
        // "interface": "wlp*",
        "format": "{ifname}",
        "interval": 5,
        "format-wifi": "´çź ",
        "format-ethernet": "´×ľ ",
        "format-disconnected": "´äž ",
        "tooltip-format": "{ifname}",
        "tooltip-format-wifi": "{essid} ´çź  {frequency}MHz\nInterface: {ifname}\nUp: {bandwidthUpBytes}\nDown: {bandwidthDownBytes}",
        "tooltip-format-ethernet": "{ifname} ´×ľ",
        "tooltip-format-disconnected": "Disconnected ´äž ",
        "on-click": "alacritty -e nmtui",
        "max-length": 50
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10,
        "show-passive-items": true
    },

    "custom/vpn": {
        "exec": "vpn st --json",
        "return-type": "json",
        "exec-on-event": true,
        "signal": 1,
        "on-click": "vpn tog"
    },

    "battery": {
        "interval": 10,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}",
        "format-alt": "{capacity}% {icon}",
        "format-charging": "{capacity}% ţ║í  {time}",
        "format-plugged": "{capacity}% ­čöî",
        "format-icons": ["ˇ░éâ", "ˇ░ü╗", "ˇ░ü╝", "ˇ░üŻ", "ˇ░üż", "ˇ░ü┐", "ˇ░éÇ", "ˇ░éü", "ˇ░éé", "ˇ░ü╣"],
        "tooltip": true
    },

    "clock": {
        "format": "{:%A, %B %d, %Y - %R}",
        "tooltip": true,
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "on-click"      : "mode",
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click": "mode"
        }
    }

}
}

