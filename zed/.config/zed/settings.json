{
  "proxy": "",
  "agent_servers": {
    "gemini": {
      "default_mode": "yolo",
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "agent": {
    "single_file_review": true,
    "dock": "right",
    "play_sound_when_agent_done": "always",
    "notify_when_agent_waiting": "all_screens",
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.4",
      "enable_thinking": false,
    },
    "model_parameters": [],
  },
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "sticky_scroll": {
    "enabled": true,
  },
  "which_key": {
    "delay_ms": 500,
    "enabled": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": false,
    },
  },
  "status_bar": { "experimental.show": true },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
  },
  "git": {
    "inline_blame": { "enabled": false },
  },
  "auto_update": true,
  "gutter": {
    "folds": true,
    "runnables": false,
    "breakpoints": true,
  },
  "relative_line_numbers": "enabled",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "never",
    "use_smartcase_find": true,
    "highlight_on_yank_duration": 200,
  },
  "toolbar": { "breadcrumbs": false, "quick_actions": false },
  "scrollbar": { "show": "never" },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "ui_font_family": "Maple Mono",
  "buffer_font_family": "Maple Mono",
  "telemetry": { "diagnostics": false, "metrics": false },
  "ui_font_size": 20.0,
  "buffer_font_size": 22.0,
  "terminal": {
    "env": { "EDITOR": "zed --wait" },
  },
  "theme": {
    "mode": "dark",
    "light": "flat᛫light",
    "dark": "Kanagawa Dragon",
  },

  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "ruff"],
    },
  },

  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "strict",
        },
        "python": {
          "pythonPath": ".venv/bin/python",
        },
      },
    },
    "ty": {
      "settings": {
        "diagnosticMode": "workspace",
      },
    },
    "pyright": {
      "binary": {
        "path": ".venv/bin/pyright-langserver",
        "arguments": ["--stdio"],
      },
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "strict",
        },
        "python": {
          "pythonPath": ".venv/bin/python",
        },
      },
    },
  },

  "theme_overrides": {
    "Kanagawa Dragon": {
      "background": "#00000088",
      "pane_group.border": "#00000000",
      "panel.background": "#00000055",
      "panel.indent_guide": "#00000000",
      "panel.indent_guide_hover": "#00000000",
      "panel.overlay_hover": "#000000ff",
      "panel.overlay_background": "#00000088",
      "editor.background": "#00000088",
      "element.background": "#00000088",
      "surface.background": "#00000088",
      "tab_bar.background": "#00000088",
      "title_bar.inactive_background": "#000000cc",
      "toolbar.background": "#00000088",
      "title_bar.background": "#000000cc",
      "terminal.background": "#00000088",
      "status_bar.background": "#000000cc",
      "predictive.background": "#00000088",
      "editor.gutter.background": "#00000088",
      "tab.active_background": "#00000088",
      "tab.inactive_background": "#00000088",
      "hidden.background": "#00000088",
      "unreachable.background": "#00000088",
      "editor.subheader.background": "#00000088",
      "ghost_element.background": "#00000000",
      "elevated_surface.background": "#000000cc",
      "border": "#00000000",
      "hint.background": "#00000000",
      "info.background": "#00000000",
      "warning.background": "#00000000",
      "error.background": "#00000000",
    },
  },
}
