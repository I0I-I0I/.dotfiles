[
  {
    "bindings": {
      "ctrl-k": null,

      "ctrl-q": "pane::CloseActiveItem",

      "alt-i": "pane::ActivatePreviousItem",
      "alt-o": "pane::ActivateNextItem",
      "alt-shift-i": "pane::SwapItemLeft",
      "alt-shift-o": "pane::SwapItemRight",
    },
  },

  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-alt-s": "workspace::SaveWithoutFormat",
      "ctrl-j": "workspace::ToggleBottomDock",
      "ctrl-l": "editor::DuplicateLineDown",
      "ctrl-shift-c": "editor::Copy",
      "ctrl-shift-v": "editor::Paste",
    },
  },

  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-w": null,

      "g o": "vim::StartOfDocument",

      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-y": ["workspace::SendKeystrokes", "4 ctrl-y"],
      "ctrl-e": ["workspace::SendKeystrokes", "4 ctrl-e"],
      "alt-j": "editor::AddSelectionBelow",
      "alt-k": "editor::AddSelectionAbove",
      "alt-n": "editor::SelectNext",
      "alt-p": "editor::SelectPrevious",
      "alt-a": "editor::SelectAllMatches",
      "alt-h": "editor::SelectLargerSyntaxNode",
      "ctrl-alt-h": "editor::SelectSmallerSyntaxNode",
      "ctrl-k h": "editor::SelectAll",
      "shift-y": ["workspace::SendKeystrokes", "y $"],

      "alt-y p": "workspace::CopyRelativePath",

      "ctrl-k g l": "git_graph::Open",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "S": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "tab": "editor::ToggleFold",
      "shift-tab": "editor::ToggleFoldRecursive",
      "ctrl-k tab": "editor::ToggleFoldAll",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-p": ["workspace::SendKeystrokes", "up"],
      "ctrl-n": ["workspace::SendKeystrokes", "down"],
      "alt-v": "pane::SplitRight",
      "alt-s": "pane::SplitDown",
      "alt-t": "workspace::NewTerminal",
      "alt-h": "workspace::ActivatePaneLeft",
      "alt-l": "workspace::ActivatePaneRight",
      "alt-j": "workspace::ActivatePaneDown",
      "alt-k": "workspace::ActivatePaneUp",
      "alt-shift-h": "workspace::MovePaneLeft",
      "alt-shift-l": "workspace::MovePaneRight",
      "alt-shift-j": "workspace::MovePaneDown",
      "alt-shift-k": "workspace::MovePaneUp",
    },
  },
]
