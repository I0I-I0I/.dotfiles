[
  {
    "key": "ctrl+s",
    "command": "workbench.action.files.save",
    "when": "editorTextFocus && !editorReadonly",
  },
  {
    "key": "ctrl+l",
    "command": "editor.action.copyLinesDownAction",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
  },
  {
    "key": "ctrl+[",
    "command": "closeReferenceSearch",
    "when": "editorFocus",
  },
  {
    "key": "ctrl+[",
    "command": "workbench.action.closeQuickOpen",
    "when": "inQuickOpen",
  },
  {
    "key": "ctrl+[",
    "command": "closeFindWidget",
    "when": "editorFocus && findWidgetVisible",
  },
  {
    "key": "ctrl+[",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus",
  },
  {
    "key": "ctrl+[",
    "command": "extension.vim_escape",
    "when": "editorTextFocus && vim.active && vim.mode != 'Normal'",
  },

  {
    "key": "shift+tab",
    "command": "editor.toggleFoldRecursively",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "shift+;",
    "command": "vim.showQuickpickCmdLine",
    "when": "editorTextFocus && vim.mode != 'Insert'",
  },

  {
    "key": "alt+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus",
  },
  {
    "key": "alt+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus",
  },

  // Tabs
  {
    "key": "alt+i",
    "command": "workbench.action.previousEditorInGroup",
  },
  {
    "key": "alt+o",
    "command": "workbench.action.nextEditorInGroup",
  },

  // Tabs
  {
    "key": "alt+shift+i",
    "command": "workbench.action.moveEditorLeftInGroup",
  },
  {
    "key": "alt+shift+o",
    "command": "workbench.action.moveEditorRightInGroup",
  },
  {
    "key": "alt+0",
    "command": "workbench.action.pinEditor",
  },
  {
    "key": "alt+w",
    "command": "workbench.action.unpinEditor",
    "when": "activeEditorIsPinned",
  },
  {
    "key": "alt+w",
    "command": "workbench.action.closeActiveEditor",
    "when": "!activeEditorIsPinned",
  },
  {
    "key": "alt+1",
    "command": "workbench.action.openEditorAtIndex1",
  },
  {
    "key": "alt+2",
    "command": "workbench.action.openEditorAtIndex2",
  },
  {
    "key": "alt+3",
    "command": "workbench.action.openEditorAtIndex3",
  },
  {
    "key": "alt+4",
    "command": "workbench.action.openEditorAtIndex4",
  },
  {
    "key": "alt+5",
    "command": "workbench.action.openEditorAtIndex5",
  },
  {
    "key": "alt+6",
    "command": "workbench.action.openEditorAtIndex6",
  },
  {
    "key": "alt+7",
    "command": "workbench.action.openEditorAtIndex7",
  },
  {
    "key": "alt+8",
    "command": "workbench.action.openEditorAtIndex8",
  },
  {
    "key": "alt+9",
    "command": "workbench.action.openEditorAtIndex9",
  },
  {
    "key": "space g w",
    "command": "workbench.action.closeOtherEditors",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "space g shift+w",
    "command": "workbench.action.closeEditorsInOtherGroups",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },

  // Zen mode
  {
    "key": "alt+z",
    "command": "workbench.action.toggleZenMode",
  },

  // Find
  {
    "key": "alt+f alt+f",
    "command": "workbench.action.quickOpen",
  },
  {
    "key": "alt+f alt+g",
    "command": "workbench.action.findInFiles",
  },
  {
    "key": "alt+f alt+b",
    "command": "workbench.action.showAllEditorsByMostRecentlyUsed",
  },
  {
    "key": "alt+f alt+k",
    "command": "workbench.action.openGlobalKeybindings",
  },
  {
    "key": "alt+f alt+o",
    "command": "workbench.action.openRecent",
  },
  {
    "key": "alt+f alt+d",
    "command": "workbench.actions.view.problems",
  },

  // Tests
  {
    "key": "alt+t t",
    "command": "testing.runAtCursor",
  },
  {
    "key": "alt+t shift+t",
    "command": "testing.runCurrentFile",
  },
  {
    "key": "alt+t a",
    "command": "testing.runAll",
  },
  {
    "key": "alt+t d",
    "command": "testing.debugAtCursor",
  },
  {
    "key": "alt+t shift+d",
    "command": "testing.debugCurrentFile",
  },
  {
    "key": "alt+t s",
    "command": "testing.toggleTestingPeekHistory",
  },
  {
    "key": "alt+t o",
    "command": "testing.openOutputPeek",
  },
  {
    "key": "alt+t alt+t",
    "command": "workbench.view.testing.focus",
  },
  {
    "key": "alt+t shift+s",
    "command": "testing.cancelTestRefresh",
  },
  {
    "key": "alt+shift+d",
    "command": "workbench.view.extension.sqltools",
  },

  // Multi-cursor
  {
    "key": "ctrl+n",
    "command": "editor.action.addSelectionToNextFindMatch",
    "when": "editorFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
  },
  {
    "key": "ctrl+p",
    "command": "editor.action.addSelectionToPreviousFindMatch",
    "when": "editorFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
  },
  {
    "key": "ctrl+j",
    "command": "editor.action.insertCursorBelow",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
  },
  {
    "key": "ctrl+k",
    "command": "editor.action.insertCursorAbove",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
  },
  {
    "key": "ctrl+a",
    "command": "editor.action.selectHighlights",
    "when": "editorFocus && vim.mode == 'Visual'",
  },
  {
    "key": "ctrl+e",
    "command": "editorScroll",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
    "args": {
      "to": "down",
      "by": "wrappedLine",
      "value": 4,
    },
  },
  {
    "key": "ctrl+y",
    "command": "editorScroll",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
    "args": {
      "to": "up",
      "by": "wrappedLine",
      "value": 4,
    },
  },

  {
    "key": "/",
    "command": "actions.find",
    "when": "editorTextFocus && (vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine')",
  },
  {
    "key": "ctrl+n",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen",
  },
  {
    "key": "ctrl+p",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen",
  },
  {
    "key": "ctrl+n",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "quickInputFocus",
  },
  {
    "key": "ctrl+p",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "quickInputFocus",
  },

  {
    "key": "alt+b",
    "command": "workbench.action.togglePanel",
  },
  {
    "key": "ctrl+j",
    "command": "-workbench.action.togglePanel",
  },

  // AI
  {
    "key": "alt+a alt+a",
    "command": "chatgpt.sidebarSecondaryView.focus",
  },
  {
    "key": "alt+a c",
    "command": "supermaven.toggle",
  },

  // Docker
  {
    "key": "alt+d alt+d",
    "command": "vscode-containers.views.containers.focus",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "alt+d r",
    "command": "vscode-containers.containers.composeGroup.start",
  },
  {
    "key": "alt+d s",
    "command": "vscode-containers.containers.composeGroup.stop",
  },
  {
    "key": "alt+d d",
    "command": "vscode-containers.containers.composeGroup.down",
  },
  {
    "key": "alt+d shift+s",
    "command": "vscode-containers.containers.composeGroup.start",
  },

  // Project Manager
  {
    "key": "alt+s s",
    "command": "projectManager.saveProject",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },
  {
    "key": "alt+f alt+s",
    "command": "projectManager.listProjects",
  },
  {
    "key": "alt+s o",
    "command": "workbench.action.files.openFolder",
    "when": "openFolderWorkspaceSupport",
  },
  {
    "key": "ctrl+f",
    "command": "workbench.action.files.openFile",
    "when": "editorTextFocus && vim.mode == 'Normal'",
  },

  // File Explorer
  {
    "key": "j",
    "command": "list.focusDown",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "k",
    "command": "list.focusUp",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "h",
    "command": "list.collapse",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "l",
    "command": "list.expand",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "enter",
    "command": "list.select",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "a",
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "shift+a",
    "command": "explorer.newFolder",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "r",
    "command": "renameFile",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "shift+d",
    "command": "deleteFile",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "x",
    "command": "filesExplorer.cut",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "c",
    "command": "filesExplorer.copy",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "p",
    "command": "filesExplorer.paste",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "y",
    "command": "copyFilePath",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "shift+y",
    "command": "copyRelativeFilePath",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "shift+r",
    "command": "workbench.files.action.refreshFilesExplorer",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": ".",
    "command": "filesExplorer.findInFolder",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "shift+h",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "tab",
    "command": "list.toggleSelection",
    "when": "filesExplorerFocus && !inputFocus",
  },

  // Git
  {
    "key": "alt+g /",
    "command": "gitlens.gitCommands",
    "when": "!gitlens:disabled && config.gitlens.keymap == 'chorded'",
  },
  {
    "key": "alt+g shift+,",
    "command": "gitlens.diffLineWithPrevious",
    "when": "editorTextFocus && config.gitlens.keymap == 'chorded' && resource in 'gitlens:tabs:tracked'",
  },
  {
    "key": "alt+g b",
    "command": "gitlens.toggleFileBlame",
    "when": "!gitlens:disabled && config.gitlens.keymap == 'chorded'",
  },
  {
    "key": "alt+g shift+l",
    "command": "git-graph.view",
    "when": "!gitlens:disabled && config.gitlens.keymap == 'chorded'",
  },
  {
    "key": "alt+g l",
    "command": "gitlens.openFileHistory",
    "when": "!gitlens:disabled && config.gitlens.keymap == 'chorded'",
  },
  {
    "key": "alt+g d",
    "command": "git.openChange",
    "when": "!gitlens:disabled && config.gitlens.keymap == 'chorded'",
  },
  {
    "key": "alt+g shift+d",
    "command": "git.viewChanges",
    "when": "!gitlens:disabled && config.gitlens.keymap == 'chorded'",
  },

  {
    "key": "alt+g alt+g",
    "command": "magit.status",
  },
  {
    "key": "g g",
    "command": "cursorTop",
    "when": "editorTextFocus && editorLangId == 'magit' && vim.mode =~ /^(?!SearchInProgressMode|CommandlineInProgress).*$/",
  },
  {
    "key": "g r",
    "command": "magit.refresh",
    "when": "editorTextFocus && editorLangId == 'magit' && vim.mode =~ /^(?!SearchInProgressMode|CommandlineInProgress).*$/",
  },
  {
    "key": "tab",
    "command": "extension.vim_tab",
    "when": "editorTextFocus && vim.active && !inDebugRepl && vim.mode != 'Insert' && !inlineEditIsVisible && editorLangId != 'magit'",
  },
  {
    "key": "tab",
    "command": "-extension.vim_tab",
  },
  {
    "key": "x",
    "command": "magit.discard-at-point",
    "when": "editorTextFocus && editorLangId == 'magit' && vim.mode =~ /^(?!SearchInProgressMode|CommandlineInProgress).*$/",
  },
  {
    "key": "k",
    "command": "-magit.discard-at-point",
  },
  {
    "key": "-",
    "command": "magit.reverse-at-point",
    "when": "editorTextFocus && editorLangId == 'magit' && vim.mode =~ /^(?!SearchInProgressMode|CommandlineInProgress).*$/",
  },
  {
    "key": "v",
    "command": "-magit.reverse-at-point",
  },
  {
    "key": "shift+-",
    "command": "magit.reverting",
    "when": "editorTextFocus && editorLangId == 'magit' && vim.mode =~ /^(?!SearchInProgressMode|CommandlineInProgress).*$/",
  },
  {
    "key": "shift+v",
    "command": "-magit.reverting",
  },
  {
    "key": "shift+o",
    "command": "magit.resetting",
    "when": "editorTextFocus && editorLangId == 'magit' && vim.mode =~ /^(?!SearchInProgressMode|CommandlineInProgress).*$/",
  },
  {
    "key": "shift+x",
    "command": "-magit.resetting",
  },
  {
    "key": "x",
    "command": "-magit.reset-mixed",
  },
  {
    "key": "ctrl+u x",
    "command": "-magit.reset-hard",
  },
]
