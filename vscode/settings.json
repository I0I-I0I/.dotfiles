{
  "window.autoDetectColorScheme": true,
  "files.simpleDialog.enable": true,
  "window.restoreWindows": "all",
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.wrapTabs": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.renderLineHighlight": "line",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "expand",
  "editor.cursorSurroundingLines": 8,
  "editor.cursorWidth": 2,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.emptySelectionClipboard": false,
  "editor.smoothScrolling": true,
  "editor.scrollBeyondLastLine": false,
  "editor.mouseWheelScrollSensitivity": 1,
  "editor.fastScrollSensitivity": 4,
  "editor.wordWrap": "on",
  "editor.wrappingIndent": "same",
  "editor.lineNumbers": "relative",
  "editor.guides.indentation": false,
  "editor.guides.highlightActiveIndentation": true,
  "editor.occurrencesHighlight": "singleFile",
  "editor.selectionHighlight": true,
  "editor.codeLens": true,
  "editor.folding": true,
  "editor.foldingStrategy": "auto",
  "editor.showFoldingControls": "always",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.bracketPairColorization.enabled": false,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true,
  },
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.preview": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "files.autoSave": "off",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": false,
  "files.trimFinalNewlines": false,
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.venv": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
  },
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.venv": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
  },
  "search.useIgnoreFiles": true,
  "search.followSymlinks": false,
  "search.smartCase": true,
  "search.searchOnType": true,
  "search.quickOpen.includeSymbols": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.copyOnSelection": false,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.scrollback": 100000,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.fontSize": 18,
  "terminal.integrated.cursorBlinking": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "explorer.decorations.colors": false,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  "diffEditor.ignoreTrimWhitespace": false,
  "extensions.ignoreRecommendations": true,
  "testing.automaticallyOpenPeekView": "never",
  "testing.followRunningTest": false,
  "debug.inlineValues": "on",
  "problems.showCurrentInStatus": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "explorer.sortOrder": "type",
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "update.mode": "manual",
  "vim.useSystemClipboard": false,
  "vim.useCtrlKeys": true,
  "vim.handleKeys": {
    "<C-f>": false,
    "<C-b>": false,
    "<C-s>": false,
    "<C-l>": false,
    "<C-j>": false,
    "<C-k>": false,
    "<C-q>": false,
    "<C-t>": false,
    "<C-e>": false,
    "<C-y>": false,
  },
  "vim.leader": " ",
  "vim.hlsearch": true,
  "vim.smartcase": true,
  "vim.incsearch": true,
  "vim.foldfix": true,
  "vim.statusBarColorControl": false,
  "vim.visualstar": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 150,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["]", "c"],
      "commands": ["workbench.action.editor.nextChange"],
    },
    {
      "before": ["[", "c"],
      "commands": ["workbench.action.editor.previousChange"],
    },
    {
      "before": ["]", "h"],
      "commands": ["workbench.action.compareEditor.nextChange"],
      "when": "textCompareEditorVisible",
    },
    {
      "before": ["[", "h"],
      "commands": ["workbench.action.compareEditor.previousChange"],

      "when": "textCompareEditorVisible",
    },

    {
      "before": ["[", "d"],
      "commands": ["editor.action.marker.prev"],
    },
    {
      "before": ["]", "d"],
      "commands": ["editor.action.marker.next"],
    },
    {
      "before": ["]", "t"],
      "commands": ["testing.goToNextMessage"],
    },
    {
      "before": ["[", "t"],
      "commands": ["testing.goToPreviousMessage"],
    },
    {
      "before": ["z", "j"],
      "commands": ["editor.gotoNextFold"],
    },
    {
      "before": ["z", "k"],
      "commands": ["editor.gotoPreviousFold"],
    },

    {
      "before": ["^"],
      "after": ["g", "^"],
    },
    {
      "before": ["$"],
      "after": ["g", "$"],
    },
    {
      "before": ["0"],
      "after": ["g", "0"],
    },
    {
      "before": ["J"],
      "after": ["m", "z", "J", "`", "z"],
    },
    {
      "before": ["n"],
      "after": ["n", "z", "z"],
    },
    {
      "before": ["N"],
      "after": ["N", "z", "z"],
    },
    {
      "before": ["g", "w"],
      "commands": ["workbench.action.closeActiveEditor"],
    },
    {
      "before": ["g", "W"],
      "commands": ["workbench.action.revertAndCloseActiveEditor"],
    },
    {
      "before": ["<leader>", "g", "w"],
      "commands": ["workbench.action.closeOtherEditors"],
    },
    {
      "before": ["<leader>", "g", "W"],
      "commands": ["workbench.action.closeEditorsInOtherGroups"],
    },
    {
      "before": ["tab"],
      "after": ["z", "a"],
    },
    {
      "before": ["<BS>"],
      "after": ["z", "c"],
    },
    {
      "before": ["-"],
      "commands": ["workbench.view.explorer"],
    },

    {
      "before": ["g", "r", "d"],
      "commands": ["workbench.actions.view.problems"],
    },
    {
      "before": ["g", "r", "a"],
      "commands": ["editor.action.quickFix"],
    },
    {
      "before": ["g", "r", "i"],
      "commands": ["editor.action.goToImplementation"],
    },
    {
      "before": ["g", "r", "n"],
      "commands": ["editor.action.rename"],
    },
    {
      "before": ["g", "r", "r"],
      "commands": ["editor.action.goToReferences"],
    },
    {
      "before": ["g", "r", "t"],
      "commands": ["editor.action.goToTypeDefinition"],
    },
    {
      "before": ["g", "O"],
      "commands": ["workbench.action.gotoSymbol"],
    },
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"],
    },
    {
      "before": ["g", "x"],
      "commands": ["editor.action.openLink"],
    },
    {
      "before": ["<leader>", "p"],
      "after": ["\"", "+", "p"],
    },
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["Y"],
      "after": ["\"", "+", "y"],
    },
    {
      "before": ["P"],
      "after": ["\"", "+", "p"],
    },
  ],
  "extensions.experimental.affinity": { "vscodevim.vim": 1 },

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "diffEditor.ignoreTrimWhitespace": true,
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off",
    },
    "editor.foldingStrategy": "auto",
    "files.trimTrailingWhitespace": false,
  },
  "workbench.activityBar.location": "top",
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "window.customTitleBarVisibility": "windowed",
  "editor.fontSize": 18,
  "editor.fontFamily": "Maple Mono, Consolas, 'Courier New', monospace",

  "workbench.panel.opensMaximized": "always",
  "workbench.secondarySideBar.forceMaximized": true,
  "workbench.secondarySideBar.defaultVisibility": "maximizedInWorkspace",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.horizontal": "hidden",

  "editor.codeActionsOnSave": { "source.organizeImports": "always" },
  "editor.foldingImportsByDefault": true,

  "magit.display-buffer-function": "same-column",

  "workbench.preferredDarkColorTheme": "Solarized Osaka",
  "workbench.preferredLightColorTheme": "Monochrome Light",
  "workbench.sideBar.location": "right",
  "gitlens.blame.highlight.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.codeLens.enabled": false,
  "zenMode.hideLineNumbers": false,
  "workbench.list.smoothScrolling": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*",
  },
  "breadcrumbs.enabled": false,
}
